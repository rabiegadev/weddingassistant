# Lokalnie: skopiuj do pliku .env (nie committuj) — na Vercel: Environment Variables.
# Wszystkie wymagane w produkcji: patrz docs/infra-checklist.md

# --- Baza: MySQL / MariaDB (SEOHost, phpMyAdmin) ---
# connection_limit: 2–5 na współdzielonym hostingu
DATABASE_URL="mysql://u_wa_dev:****@sXX.seohost.pl:3306/weddingassistant_dev?connection_limit=2"
# Tylko jeśli w prisma/schema.datasource dodałeś: shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
# Druga, pusta baza ręcznie w panelu hosta — umożliwia `prisma migrate dev` bez CREATE DATABASE
# SHADOW_DATABASE_URL="mysql://u_wa_dev:****@sXX.seohost.pl:3306/weddingassistant_shadow"

# --- Aplikacja: kanoniczny URL (linki w mailach) ---
NEXT_PUBLIC_APP_URL="https://weddingassistant.pl"

# --- Poczta: SMTP (nodemailer) albo w jednym wierszu: ---
# Vercel: te same zmienne w Environment Variables — dla strony produkcyjnej wklej w „Production”;
# preview z branchy potrzebuje osobno w „Preview”, inaczej deploy preview nie ma SMTP.
# Rejestracja: jeśli mail nie dochodzi, Vercel → tab Logs → filtr [mail] (błąd wysyłki / brak transportu).
# Częsty błąd: MAIL_FROM inna domena niż skrzynka SMTP; hosting wymaga nadawcy z własnej domeny.
SMTP_URL="smtp://user:password@smtp.seohost.pl:587?encryption=STARTTLS"
MAIL_FROM="Weddingassistant <noreply@weddingassistant.pl>"
# Alternatywnie: MAIL_FROM, SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, SMTP_SECURE
ADMIN_NOTIFY_EMAILS="kontakt@weddingassistant.pl"   # wielu po przecinku: a@b.pl,b@c.pl

# Cloudflare Turnstile (captcha) — w dev może być puste, w prod wymagane
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAA..."
TURNSTILE_SECRET_KEY="0x4AAAA..."

# 2FA admina (szyfrowanie sekretu w bazie); wygeneruj: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=""

# Seed: jednorazowe (npx tsx prisma/seed.ts albo npm run db:seed) — silne, losowe; w prod tylko świadomie
# SEED_ADMIN_PASSWORD="**********"
# SEED_ADMIN_EMAIL="admin@twoja-domena.pl"
# SEED_DEMO_USER_EMAIL="para@example.com"   # opcjonalnie: konto demo pary
# SEED_DEMO_USER_PASSWORD="**********"

# Sentry (opcjonalne) — dziennik błędów w produkcji; `instrumentation.ts` ładuje tylko gdy ustawione
# SENTRY_DSN="https://____@____.ingest.sentry.io/____"
# NEXT_PUBLIC_SENTRY_DSN= (opcjonalnie, jeśli błędy po stronie klienta)
